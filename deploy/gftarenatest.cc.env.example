# Окружение для СЕРВЕРА API на поддомене api.gftarenatest.cc (тот же репо, тот же server/index.mjs).
# Браузер с сайта gftarenatest.cc шлёт Origin: https://gftarenatest.cc — он должен быть в FRONTEND_ORIGIN.
PORT=5055
NODE_ENV=production
FRONTEND_ORIGIN=https://gftarenatest.cc,https://www.gftarenatest.cc

# Статика (gftarenatest.cc): перед npm run build в корне репо должен быть .env.production с
# VITE_API_BASE=https://api.gftarenatest.cc
# (уже лежит в репозитории как .env.production)

# CORS_STRICT=1  — только FRONTEND_ORIGIN + dev/tunnel; для жёсткого прода включи
