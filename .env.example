# Ключи: https://apps.xumm.dev/ — не коммить реальные значения. После утечки перевыпусти в кабинете.
XUMM_API_KEY=your_key_here
XUMM_API_SECRET=your_secret_here

# Render / прод: те же имена переменных добавь в Dashboard → Environment (значения вручную).
# Root Directory пустой. Build: npm ci && npm run build. Start: node server/index.mjs
# Данные (players.json, progress.json, …): локально — каталог data/. На Render: Persistent Disk в /data и DATA_DIR=/data (см. render.yaml).
# DATA_DIR=/data

# CORS: один URL или несколько через запятую (например www и apex).
# Прод: см. deploy/gftarenatest.cc.env.example
# FRONTEND_ORIGIN=https://gftarenatest.cc,https://www.gftarenatest.cc
FRONTEND_ORIGIN=http://localhost:5173

# URL API для собранного фронта (задаётся при `npm run build` через .env.production).
# Прод с API на поддомене: см. .env.production в репозитории (VITE_API_BASE=https://api.gftarenatest.cc).
# В `npm run dev` обычно не нужен — запросы идут на /api и Vite проксирует на :5055.
# VITE_API_BASE=https://api.gftarenatest.cc

# Server port
PORT=5055

# Admin: GET /api/admin/presence?maxAgeSec=120
# Send header: X-Admin-Token: <this>
# Example: curl -H "X-Admin-Token: yoursecret" https://your-host/api/admin/presence
ADMIN_TOKEN=change_me_to_a_long_random_string

# Random virtual NFT for beta (collections 1–2 only: Dual Force, CRYPTO ALLIANCE; does not mint on XRPL):
# curl -X POST -H "Content-Type: application/json" -H "X-Admin-Token: yoursecret" -d "{\"sampleSize\":6,\"maxEach\":2}" https://your-host/api/admin/nft-sim/roll
# Optional third collection in same roll: add "includeGenesis":true

# Admin grant (currency / materials / shards / cards) by numeric player id:
# curl -X POST -H "Content-Type: application/json" -H "X-Admin-Token: yoursecret" -d "{\"currencies\":{\"coins\":1000,\"crystals\":50},\"materials\":10}" https://your-host/api/admin/player/12345/grant

# Deposit destination (your project treasury)
TREASURY_XRPL_ADDRESS=rYourTreasuryAddressHere

# TON: shop coin packs in TON (user-friendly UQ.../EQ...). Without this, TON purchases are disabled.
# TON_TREASURY_ADDRESS=UQ...

# GFT issued currency settings (from Magnetic token page)
GFT_CURRENCY=GFT
GFT_ISSUER=rn5SUAg2utJAcjvhBfQpLgtSqakxWESLBe

